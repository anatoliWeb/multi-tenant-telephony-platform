<include>
  <!-- Local demo bridge rules for FreeSWITCH development only.
       The provisioning script copies this file into the running container
       for both the public and default dialplan contexts after substituting the
       runtime-domain value detected from global_getvar local_ip_v4. -->
  <extension name="local-demo-extension-bridge">
    <condition field="destination_number" expression="^(1001|1002|2001|2002)$" break="on-true">
      <action application="set" data="hangup_after_bridge=true"/>
      <!-- SIP.js registrations must bridge to the live Sofia contact so the
           local WebRTC contact URI, fs_path, and transport parameters stay
           intact during the local demo call. -->
      <action application="set" data="local_demo_contact=${sofia_contact(*/${destination_number}@__RUNTIME_DOMAIN__)}"/>
    </condition>

    <condition field="${local_demo_contact}" expression="^$">
      <action application="respond" data="480 Temporarily Unavailable"/>
      <action application="hangup" data="USER_NOT_REGISTERED"/>
    </condition>

    <condition field="${local_demo_contact}" expression=".+">
      <action application="bridge" data="${local_demo_contact}"/>
    </condition>
  </extension>
</include>
