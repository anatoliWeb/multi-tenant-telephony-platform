# ===============================

# Application

# ===============================

APP_NAME="Multi-Tenant Telephony Platform"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# ===============================

# Ports (Single source of truth)

# ===============================

# Backend (Nginx -> Laravel)

APP_PORT=8080

# Angular Dashboard

FRONT_PORT=4200

# ===============================

# Database (MySQL)

# ===============================

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=saas
DB_USERNAME=saas
DB_PASSWORD=secret

# Dedicated MySQL database for Laravel test suite.
# Safe to recreate/drop during automated tests.
TEST_DB_DATABASE=saas_testing
TEST_DB_USERNAME=saas
TEST_DB_PASSWORD=secret

# Root password for MySQL container

MYSQL_ROOT_PASSWORD=root

# ===============================

# Redis (Queues, Cache, Realtime)

# ===============================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=secret

# ===============================

# Queue

# ===============================

QUEUE_CONNECTION=redis

# ===============================

# FreeSWITCH (Optional Local Demo)

# ===============================

# FreeSWITCH stays optional and the fake provider remains the default unless
# local demo credentials are explicitly enabled for developer testing.
FREESWITCH_ENABLED=false
FREESWITCH_LOCAL_DEMO_CREDENTIALS=false
FREESWITCH_HOST=freeswitch
FREESWITCH_SIP_DOMAIN=localhost
FREESWITCH_WEBRTC_WSS_URL=wss://localhost:7443
FREESWITCH_DEFAULT_SIP_PASSWORD=change_me_local_demo_only
FREESWITCH_SIP_PORT=5060
FREESWITCH_SIP_TLS_PORT=5061
FREESWITCH_WSS_PORT=7443
FREESWITCH_RTP_START_PORT=16384
FREESWITCH_RTP_END_PORT=32768
FREESWITCH_EVENT_SOCKET_PORT=8021
FREESWITCH_EVENT_SOCKET_PASSWORD=

# ===============================

# Broadcasting / WebSockets

# ===============================

BROADCAST_DRIVER=reverb

REVERB_APP_ID=app-id
REVERB_APP_KEY=app-key
REVERB_APP_SECRET=app-secret

REVERB_HOST=localhost
REVERB_PORT=6001
REVERB_SCHEME=http

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080

# ===============================

# Frontend (Angular / Vue)

# ===============================

# Used by frontend apps to connect to API

VITE_API_URL=http://localhost:${APP_PORT}/api

# ===============================

# Logging

# ===============================

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ===============================

# Notes

# ===============================

# - Do NOT commit .env (only .env.example)

# - Ports are controlled only here

# - Docker uses this file as single source of truth

# - Frontend and backend must read values from here
