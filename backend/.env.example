
############################################################
# 🧠 Application Core
############################################################

APP_NAME=Laravel
APP_ENV=local
APP_KEY=                    # Generated via: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost

############################################################
# 🌍 Localization
############################################################

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

############################################################
# 🛠 Maintenance Mode
############################################################

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

############################################################
# 🔐 Security
############################################################

BCRYPT_ROUNDS=12
SECURITY_RATE_LIMITS_ENABLED=true
SECURITY_HEADERS_ENABLED=true
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=()
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=false
SECURITY_CSP_ENABLED=true
SECURITY_CSP_REPORT_ONLY=false
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_LOGIN_RATE_LIMIT_DECAY_SECONDS=60
API_DOCS_RATE_LIMIT_MAX_ATTEMPTS=60
API_DOCS_RATE_LIMIT_DECAY_SECONDS=60
CHAT_TYPING_RATE_LIMIT_MAX_ATTEMPTS=120
CHAT_TYPING_RATE_LIMIT_DECAY_SECONDS=60
CHAT_ATTACHMENT_RATE_LIMIT_MAX_ATTEMPTS=20
CHAT_ATTACHMENT_RATE_LIMIT_DECAY_SECONDS=60

MONITORING_HEALTH_ENABLED=true
MONITORING_HEALTH_PROTECTED_ENABLED=true
MONITORING_HEALTH_TIMEOUT_MS=500
MONITORING_HEALTH_EXPOSE_DETAILS=false
MONITORING_HEALTH_CHECK_DATABASE=true
MONITORING_HEALTH_CHECK_REDIS=true
MONITORING_HEALTH_CHECK_CACHE=true
MONITORING_HEALTH_CHECK_QUEUE=true

############################################################
# 📜 Logging
############################################################

LOG_CHANNEL=stack
# Local development default keeps file log for convenience.
# Container/dev/prod readiness recommendation:
# - use LOG_CHANNEL=stack and LOG_STACK=stderr for container-first logging
# - or LOG_CHANNEL=stderr directly
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_STRUCTURED_CONTEXT=true
LOG_QUEUE_EVENTS=true
LOG_REALTIME_EVENTS=true
LOG_REALTIME_CHANNEL_AUTH_FAILURES=true
LOG_REALTIME_BROADCAST_FAILURES=true
LOG_REALTIME_PRESENCE_SUMMARY=false

############################################################
# 🗄 Database
############################################################

# Docker example:
# DB_HOST=mysql
# Local example:
# DB_HOST=127.0.0.1

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=saas
DB_USERNAME=saas
DB_PASSWORD=secret
DB_TEST_DATABASE=saas_testing
DB_TEST_USERNAME=saas
DB_TEST_PASSWORD=secret

# Testing database isolation:
# Laravel tests must run against a dedicated DB to avoid wiping local dev data.
# Recommended test DB name: saas_testing (configured in backend/.env.testing).
# Optional explicit override key used by tests bootstrap:
# DB_TEST_DATABASE=saas_testing
# Create once in MySQL:
# CREATE DATABASE IF NOT EXISTS saas_testing CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;

############################################################
# 🍪 Sessions
############################################################

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

############################################################
# 📡 Broadcasting / Queue / Filesystem
############################################################

BROADCAST_DRIVER=reverb
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=90
REDIS_QUEUE_BLOCK_FOR=5
QUEUE_FAILED_DRIVER=database-uuids
QUEUE_WORKER_QUEUES=webhooks,realtime,notifications,activity,emails,default,low
QUEUE_WORKER_SLEEP=1
QUEUE_WORKER_TRIES=3
QUEUE_WORKER_TIMEOUT=90
QUEUE_WORKER_BACKOFF=10
QUEUE_WORKER_MAX_TIME=3600
QUEUE_WORKER_MAX_JOBS=1000
HORIZON_NAME=saas-horizon
HORIZON_PATH=horizon
# Optional: if using custom subdomain for Horizon dashboard
HORIZON_DOMAIN=

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080
SANCTUM_TOKEN_EXPIRATION=1440

REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=6001
REVERB_APP_KEY=app-key
REVERB_APP_SECRET=app-secret
REVERB_APP_ID=app-id
REVERB_HOST=localhost
REVERB_PORT=6001
REVERB_SCHEME=http
REVERB_BROADCAST_HOST=reverb

############################################################
# ⚡ Cache
############################################################

CACHE_STORE=redis
# Optional dedicated cache store override for performance caches.
PERFORMANCE_CACHE_STORE=
PERFORMANCE_CACHE_ENABLED=true
PERFORMANCE_CACHE_DEFAULT_TTL=300
PERFORMANCE_CACHE_META_TTL=300
PERFORMANCE_CACHE_RBAC_TTL=600
PERFORMANCE_CACHE_STATS_TTL=60
PERFORMANCE_CACHE_API_DOCS_TTL=600
# Effective permissions cache TTL in seconds
RBAC_PERMISSIONS_CACHE_TTL=600
# CACHE_PREFIX=

############################################################
# 🚀 Redis
############################################################

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

############################################################
# 📧 Mail
############################################################

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

############################################################
# ☁️ AWS (optional)
############################################################

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

############################################################
# 🌐 CORS (Frontend Access)
############################################################

# Comma-separated list of allowed frontend origins
# Example:
# http://localhost:5173,https://app.myproject.com
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:5173

############################################################
# ⚛️ Frontend (Vite)
############################################################

VITE_APP_NAME="${APP_NAME}"

# Base API URL used by React frontend
VITE_API_BASE_URL=http://localhost:8080/api
VITE_BUILD_SOURCEMAP=false
VITE_DROP_CONSOLE=false

# Vue Admin realtime (Reverb / Echo)
VITE_REVERB_APP_KEY=app-key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=6001
VITE_REVERB_SCHEME=http
VITE_REVERB_FORCE_TLS=false
VITE_REVERB_USE_PRIVATE_CHANNEL=true

# Chat attachments
CHAT_ATTACHMENTS_DISK=local
CHAT_ATTACHMENTS_MAX_SIZE_KB=10240
CHAT_ATTACHMENTS_VIRUS_SCAN_ENABLED=false
CHAT_TYPING_THROTTLE_SECONDS=2
CHAT_PRESENCE_STALE_AFTER_SECONDS=120
CHAT_MESSAGE_SEND_RATE_LIMIT_ENABLED=true
CHAT_MESSAGE_SEND_RATE_LIMIT_MAX_ATTEMPTS=30
CHAT_MESSAGE_SEND_RATE_LIMIT_DECAY_SECONDS=60
CHAT_EXTERNAL_API_TOKEN_PREFIX=chat_ext_
CHAT_EXTERNAL_API_TOKEN_SCOPES_DEFAULT=chat.external.messages.send
CHAT_EXTERNAL_API_RATE_LIMIT_ENABLED=true
CHAT_EXTERNAL_API_RATE_LIMIT_MAX_ATTEMPTS=60
CHAT_EXTERNAL_API_RATE_LIMIT_DECAY_SECONDS=60
CHAT_WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300
CHAT_WEBHOOK_REPLAY_PROTECTION_ENABLED=true
CHAT_WEBHOOK_REPLAY_PROTECTION_TTL_SECONDS=300
CHAT_WEBHOOK_MAX_ATTEMPTS=5
CHAT_WEBHOOK_SECRET_ROTATION_GRACE_SECONDS=86400
CHAT_WEBHOOK_MANAGEMENT_RATE_LIMIT_MAX_ATTEMPTS=30
CHAT_WEBHOOK_MANAGEMENT_RATE_LIMIT_DECAY_SECONDS=60
CHAT_SUSPICIOUS_ACTIVITY_ENABLED=true
CHAT_SUSPICIOUS_ACTIVITY_LOG_ONLY=true
CHAT_SUSPICIOUS_ACTIVITY_MAX_MESSAGE_LENGTH=5000
CHAT_SUSPICIOUS_ACTIVITY_MAX_ATTACHMENTS=10
CHAT_ACTIVITY_INTEGRATION_ENABLED=true
API_DOCS_LOCAL_BYPASS=false

# Angular realtime config is defined in:
# frontend/src/environments/environment*.ts
# (Angular does not read VITE_* variables directly.)
