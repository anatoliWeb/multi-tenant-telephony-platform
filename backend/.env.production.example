APP_NAME=Multi-Tenant Telephony Platform
APP_ENV=production
APP_KEY=base64:CHANGE_ME_GENERATED_KEY
APP_DEBUG=false
APP_URL=https://example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_LEVEL=info
LOG_STRUCTURED_CONTEXT=true
LOG_QUEUE_EVENTS=true
LOG_REALTIME_EVENTS=true

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=saas
DB_USERNAME=saas
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

CACHE_STORE=redis
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids

SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true
SESSION_DOMAIN=example.com

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

SANCTUM_STATEFUL_DOMAINS=example.com,api.example.com
SANCTUM_TOKEN_EXPIRATION=1440

SECURITY_RATE_LIMITS_ENABLED=true
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=false
SECURITY_CSP_ENABLED=true
SECURITY_CSP_REPORT_ONLY=false
API_DOCS_LOCAL_BYPASS=false

MONITORING_HEALTH_ENABLED=true
MONITORING_HEALTH_PROTECTED_ENABLED=true
MONITORING_HEALTH_EXPOSE_DETAILS=false

PERFORMANCE_CACHE_ENABLED=true
PERFORMANCE_CACHE_DEFAULT_TTL=300
PERFORMANCE_CACHE_META_TTL=300
PERFORMANCE_CACHE_RBAC_TTL=600
PERFORMANCE_CACHE_STATS_TTL=60
PERFORMANCE_CACHE_API_DOCS_TTL=600

REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=6001
REVERB_APP_KEY=CHANGE_ME_REVERB_APP_KEY
REVERB_APP_SECRET=CHANGE_ME_REVERB_APP_SECRET
REVERB_APP_ID=CHANGE_ME_REVERB_APP_ID
REVERB_HOST=realtime.example.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_BROADCAST_HOST=reverb

VITE_API_BASE_URL=https://example.com/api
VITE_REVERB_APP_KEY=CHANGE_ME_REVERB_APP_KEY
VITE_REVERB_HOST=realtime.example.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
VITE_REVERB_FORCE_TLS=true
