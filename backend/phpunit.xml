<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <ini name="memory_limit" value="512M"/>
        <server name="APP_ENV" value="testing"/>
        <server name="APP_KEY" value="base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="/>
        <server name="DB_CONNECTION" value="mysql"/>
        <server name="DB_HOST" value="mysql"/>
        <server name="DB_PORT" value="3306"/>
        <server name="DB_DATABASE" value="saas_testing"/>
        <server name="DB_TEST_DATABASE" value="saas_testing"/>
        <server name="DB_USERNAME" value="saas"/>
        <server name="DB_PASSWORD" value="secret"/>
        <server name="DB_TEST_USERNAME" value="saas"/>
        <server name="DB_TEST_PASSWORD" value="secret"/>
        <server name="MYSQL_ATTR_SSL_VERIFY_SERVER_CERT" value="false"/>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_KEY" value="base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="mysql"/>
        <env name="DB_HOST" value="mysql"/>
        <env name="DB_PORT" value="3306"/>
        <env name="DB_DATABASE" value="saas_testing"/>
        <env name="DB_TEST_DATABASE" value="saas_testing"/>
        <env name="DB_USERNAME" value="saas"/>
        <env name="DB_PASSWORD" value="secret"/>
        <env name="DB_TEST_USERNAME" value="saas"/>
        <env name="DB_TEST_PASSWORD" value="secret"/>
        <env name="MYSQL_ATTR_SSL_VERIFY_SERVER_CERT" value="false"/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
